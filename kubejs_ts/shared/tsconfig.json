{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "plugins": [],
    "checkJs": false,

    "strict": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,

    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "useUnknownInCatchVariables": true,

    "noEmit": true,
    "skipLibCheck": true,

    "lib": [
      "ES2022"
    ],
    "paths": {
      "kubejs_ts/types": [
        "../types"
      ],
      "kubejs_ts/types/*": [
        "../types/*"
      ],
      "kubejs_ts/shared/*": [
        "../shared/*"
      ],
      "@package": [
        "../../.probe/@package"
      ],
      "@package/*": [
        "../../.probe/@package/*"
      ],
      "@side-only/startup": [
        "../../.probe/@side-only/startup"
      ],
      "@side-only/startup/*": [
        "../../.probe/@side-only/startup/*"
      ],
      "@side-only/server": [
        "../../.probe/@side-only/server"
      ],
      "@side-only/server/*": [
        "../../.probe/@side-only/server/*"
      ],
      "@special": [
        "../../.probe/@special"
      ],
      "@special/*": [
        "../../.probe/@special/*"
      ]
    },
  },
  "include": [
    "../**/*.ts",
    "../**/*.d.ts",
    "../../.probe/@package/**/*.d.ts",
    "../../.probe/@side-only/startup/**/*.d.ts",
    "../../.probe/@side-only/server/**/*.d.ts",
    "../../.probe/@special/**/*.d.ts"
  ]
}
